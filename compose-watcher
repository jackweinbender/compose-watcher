#!/usr/bin/env bash
# compose-watcher: watch a directory for docker-compose project folders.
# Drop a folder with a .yml â†’ `docker compose up`. Remove the folder â†’ `docker compose down -v --rmi local`.
# Depends on: inotifywait (inotify-tools), docker compose, flock.
# Env: WATCH_DIR (default /etc/compose-stacks), LOCK_DIR (default /run/compose-watcher).
set -euo pipefail
trap 'exit 0' INT TERM

WATCH_DIR="${WATCH_DIR:-/etc/compose-stacks}"
LOCK_DIR="${LOCK_DIR:-/run/compose-watcher}"

# Project name = immediate subdirectory under watch root.
#   /etc/compose-stacks/myproject/docker-compose.yml  â†’ myproject
project_name() {
    echo "${2#${1}/}" | cut -d/ -f1
}

# Run in background; per-project flock prevents concurrent ops.
compose_up() {
    ( exec 9>"$LOCK_DIR/$1.lock"
      flock -n 9 || exit 0
      echo "INFO up starting project=$1 file=$2"
      if docker compose -p "$1" -f "$2" up -d --remove-orphans >/dev/null 2>&1
      then echo "INFO up complete project=$1"
      else echo "ERROR up failed project=$1 exit_code=$?"
      fi ) &
}

compose_down() {
    ( exec 9>"$LOCK_DIR/$1.lock"
      flock -n 9 || exit 0
      echo "INFO down starting project=$1"
      if docker compose -p "$1" down -v --rmi local >/dev/null 2>&1
      then echo "INFO down complete project=$1"
      else echo "ERROR down failed project=$1 exit_code=$?"
      fi ) &
}

# Upsert every existing .yml/.yaml one level deep â€” makes daemon restarts idempotent.
startup_scan() {
    while IFS= read -r -d '' f; do
        compose_up "$(project_name "$WATCH_DIR" "$f")" "$f"
    done < <(find "$WATCH_DIR" -mindepth 2 -maxdepth 2 \( -name '*.yml' -o -name '*.yaml' \) -print0 2>/dev/null)
}

# Runs inotifywait in monitor mode. Exits when a new subdirectory appears
# so systemd restarts us with fresh recursive watches + a fresh startup_scan
# (inotify doesn't auto-recurse into dirs created after the watch starts).
event_loop() {
    inotifywait -mr --format '%w%f %e' \
        -e close_write -e moved_to -e delete -e create \
        "$WATCH_DIR" 2>/dev/null |
    while IFS=' ' read -r path event; do
        if [[ "$event" == *ISDIR* ]]; then
            [[ "$event" == DELETE* ]] && compose_down "$(project_name "$WATCH_DIR" "$path")" || { echo "INFO new dir path=$path"; break; }
            continue
        fi
        [[ "$(dirname "$path")" == "$WATCH_DIR" ]] && continue
        case "$path" in *.yml|*.yaml) ;; *) continue;; esac
        local p; p=$(project_name "$WATCH_DIR" "$path")
        echo "INFO event=$event path=$path project=$p"
        case "$event" in
            CLOSE_WRITE*|MOVED_TO*) compose_up   "$p" "$path" ;;
            DELETE*)                compose_down "$p" ;;
        esac
    done
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    mkdir -p "$LOCK_DIR"
    echo "INFO starting watch_dir=$WATCH_DIR"
    startup_scan
    event_loop
fi
